# VisualNote environment template
# Copy to .env and fill in real values.

# === Provider switch ===
# Set MIMO_USE_MOCK=true to run the entire pipeline without any API calls.
# Useful for local development, CI, and end-to-end smoke tests.
MIMO_USE_MOCK=false

# === LLM (Kilo Code AI Gateway) ===
# Kilo exposes an OpenAI-compatible gateway at https://api.kilo.ai/api/gateway.
# Model IDs use the "provider/model" format, e.g.:
#   kilo-auto/free                                 (rotates free models)
#   stepfun/step-3.7-flash:free                    (free; strong for JSON + code)
#   nvidia/nemotron-3-super-120b-a12b:free         (free; native structured outputs)
#   anthropic/claude-sonnet-4.5                    (paid)
#   google/gemini-2.5-pro                          (paid)
# Browse the full list: GET https://api.kilo.ai/api/gateway/models
KILO_BASE_URL=https://api.kilo.ai/api/gateway
KILO_API_KEY=
# Default to a free model so the pipeline runs without paid credits.
KILO_MODEL=kilo-auto/free
KILO_FALLBACK_MODEL=stepfun/step-3.7-flash:free

# === MiMo V2.5 TTS (Xiaomi MiMo Open Platform) ===
# MiMo TTS is NOT OpenAI-audio-compatible: it lives at /v1/chat/completions with
# an `audio` field on the request and returns base64-encoded PCM in
# `choices[0].message.audio.data` (48kHz / 16-bit / mono).
# Auth uses the `api-key` header (not Authorization: Bearer).
MIMO_TTS_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_API_KEY=
MIMO_TTS_MODEL=mimo-v2.5-tts
# Built-in voice preset. Common values: Chloe, mimo_default, Brian, Emma, etc.
MIMO_TTS_VOICE=Chloe

# === Runtime ===
# Override these only if the auto-detected binaries are wrong.
FFMPEG_PATH=
MANIM_PATH=

# Default output resolution: 1080p or 720p.
DEFAULT_RESOLUTION=1080p

# === Optional: local TTS fallback (Phase 2) ===
# If the MiMo TTS endpoint fails, the pipeline can fall back to Coqui TTS
# running locally. Set COQUI_TTS_MODEL to a model name from `tts --list_models`.
COQUI_TTS_MODEL=
COQUI_TTS_VOICE=

# === Image Generation (NVIDIA NIM Qwen Image) ===
# Get your API key from https://build.nvidia.com
# The qwen-image model generates educational diagrams and illustrations.
NVIDIA_NIM_API_KEY=
