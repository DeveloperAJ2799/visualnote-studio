# VisualNote environment template
# Copy to .env and fill in real values.

# === MiMo V2.5 LLM ===
# Set MIMO_USE_MOCK=true to run the entire pipeline without any API calls.
# Useful for local development, CI, and end-to-end smoke tests.
MIMO_USE_MOCK=true

# Base URL for the MiMo V2.5 chat completions endpoint.
# TODO(MIMO): confirm the exact base URL against the MiMo Open Platform docs.
MIMO_BASE_URL=https://api.mimo.mi.com/v1

# API key for the MiMo V2.5 chat completions endpoint.
MIMO_API_KEY=

# Default model identifier for LLM calls.
MIMO_MODEL=mimo-v2.5

# Fallback model used for complex reasoning segments.
MIMO_FALLBACK_MODEL=mimo-v2.5-pro

# === MiMo V2.5 TTS ===
# TODO(MIMO): confirm the exact base URL for the TTS endpoint.
MIMO_TTS_BASE_URL=https://api.mimo.mi.com/v1
MIMO_TTS_API_KEY=
MIMO_TTS_MODEL=mimo-v2.5-tts

# Default TTS voice preset. PRD specifies "instructor".
MIMO_TTS_VOICE=instructor

# === Runtime ===
# Override these only if the auto-detected binaries are wrong.
FFMPEG_PATH=
MANIM_PATH=

# Default output resolution: 1080p or 720p.
DEFAULT_RESOLUTION=1080p

# === Optional: local TTS fallback (Phase 2) ===
# If the MiMo TTS endpoint fails, the pipeline can fall back to Coqui TTS
# running locally. Set COQUI_TTS_MODEL to a model name from `tts --list_models`.
COQUI_TTS_MODEL=
COQUI_TTS_VOICE=
